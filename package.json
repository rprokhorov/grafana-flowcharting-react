{
  "name": "grafana-flowcharting-react",
  "version": "0.1.0",
  "description": "FlowCharting React panel plugin for Grafana 10+",
  "keywords": [
    "grafana",
    "grafana-panel",
    "flowchart",
    "drawio",
    "mxgraph",
    "diagram"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rprokhorov/grafana-flowcharting-react.git"
  },
  "homepage": "https://github.com/rprokhorov/grafana-flowcharting-react#readme",
  "bugs": {
    "url": "https://github.com/rprokhorov/grafana-flowcharting-react/issues"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "test": "jest --passWithNoTests",
    "dev": "webpack --config webpack.config.js --watch",
    "watch": "webpack --config webpack.config.js --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:gen-dashboard": "ts-node --compiler-options '{\"module\":\"commonjs\"}' e2e/gen-dashboard.ts"
  },
  "author": "Roman Prokhorov",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/data": "^10.4.0",
    "@grafana/plugin-e2e": "^3.9.0",
    "@grafana/runtime": "^10.4.0",
    "@grafana/schema": "^10.4.0",
    "@grafana/tsconfig": "^2.0.1",
    "@grafana/ui": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/chroma-js": "^3.1.2",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "chroma-js": "^2.4.2",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "nanoid": "^5.0.0",
    "pako": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0"
  }
}
